# Optional cloud sync (Supabase). Copy this file to `.env` and fill in the two
# values from your Supabase project (Project Settings -> API). Both are safe to
# expose in the browser; Row Level Security protects the data.
#
# Leave these unset and the app runs fully local-first with no account UI.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
